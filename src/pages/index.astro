---
import BaseHead from '../layouts/BaseHead.astro';

// Tools (everything except studies, guides, lists)
const tools = [
  { emoji: "⚡", name: "DevBox", slug: "/devbox", desc: "Auto-detect dev strings — JSON, JWT, base64, timestamps, colors, regex, cron, URLs" },
  { emoji: "⚙️", name: "chmod Calculator", slug: "/chmod-calculator", desc: "Visual Linux file permission editor with octal & symbolic notation" },
  { emoji: "🔤", name: "Base64 Encoder/Decoder", slug: "/base64", desc: "Encode/decode Base64. Supports files, images, URL-safe mode" },
  { emoji: "⏰", name: "Cron Expression Generator", slug: "/cron-generator", desc: "Build cron expressions visually with schedule preview" },
  { emoji: "📋", name: "JSON Formatter & Validator", slug: "/json-formatter", desc: "Format, validate, minify JSON with syntax highlighting" },
  { emoji: "🔗", name: "UTM Builder", slug: "/utm-builder", desc: "Generate UTM-tagged URLs for campaign tracking" },
  { emoji: "🎨", name: "Color Converter", slug: "/color-converter", desc: "Convert HEX, RGB, HSL, CMYK with visual picker" },
  { emoji: "🔍", name: "Regex Tester", slug: "/regex-tester", desc: "Test regex patterns with real-time highlighting" },
  { emoji: "🔐", name: "Hash Generator", slug: "/hash-generator", desc: "Generate MD5, SHA-1, SHA-256, SHA-512 hashes" },
  { emoji: "🏷️", name: "HTML Entities Encoder", slug: "/html-entities", desc: "Encode/decode special characters to HTML entities" },
  { emoji: "📦", name: "JavaScript Minifier", slug: "/js-minifier", desc: "Minify JS code for production builds" },
  { emoji: "🔄", name: "CSV ↔ JSON Converter", slug: "/csv-json", desc: "Convert between CSV and JSON with file support" },
  { emoji: "🔑", name: "Password Generator", slug: "/password-generator", desc: "Generate strong passwords with custom criteria" },
  { emoji: "🏗️", name: "Meta Tag Generator", slug: "/meta-tag-generator", desc: "Generate SEO meta tags & Open Graph preview" },
  { emoji: "🌐", name: "URL Encoder/Decoder", slug: "/url-encoder", desc: "Encode/decode URLs and query parameters" },
  { emoji: "🗄️", name: "SQL Formatter", slug: "/sql-formatter", desc: "Format SQL queries with proper indentation" },
  { emoji: "📄", name: "Markdown Live Preview", slug: "/markdown-preview", desc: "Write Markdown with real-time HTML preview" },
  { emoji: "🔄", name: "YAML ↔ JSON Converter", slug: "/yaml-json", desc: "Convert between YAML and JSON with validation" },
  { emoji: "📝", name: "Lorem Ipsum Generator", slug: "/lorem-ipsum", desc: "Generate placeholder text in paragraphs or words" },
  { emoji: "🆔", name: "UUID Generator", slug: "/uuid-generator", desc: "Generate UUID v1, v4, v7. Parse and validate UUIDs" },
  { emoji: "📱", name: "QR Code Generator", slug: "/qr-generator", desc: "Generate QR codes with size/color customization" },
  { emoji: "🎨", name: "CSS Minifier", slug: "/css-minifier", desc: "Minify CSS for production builds" },
  { emoji: "👁️", name: "Open Graph Preview", slug: "/og-preview", desc: "Preview URL sharing on Facebook, Twitter, LinkedIn" },
  { emoji: "🔄", name: "XML ↔ JSON Converter", slug: "/xml-json", desc: "Convert XML to JSON with attribute handling" },
  { emoji: "🤖", name: "robots.txt Generator", slug: "/robots-txt", desc: "Build robots.txt with user agents & sitemaps" },
  { emoji: "📋", name: "Text Diff Checker", slug: "/diff-checker", desc: "Compare texts with line-by-line diff highlighting" },
  { emoji: "🔢", name: "Word & Character Counter", slug: "/word-counter", desc: "Count words, chars, sentences with reading time" },
  { emoji: "🌐", name: "Subnet Calculator", slug: "/subnet-calculator", desc: "Calculate subnet masks, network & broadcast addresses" },
  { emoji: "🔓", name: "String Escape/Unescape", slug: "/escape-unescape", desc: "Escape strings for JSON, HTML, XML, URL, JavaScript" },
  { emoji: "🔄", name: "HTML ↔ Markdown Converter", slug: "/html-markdown", desc: "Convert between HTML and Markdown formats" },
  { emoji: "⏱️", name: "Timestamp Converter", slug: "/timestamp-converter", desc: "Convert Unix timestamps with timezone support" },
  { emoji: "🔢", name: "Number Base Converter", slug: "/number-base", desc: "Convert binary, octal, decimal, hexadecimal" },
  { emoji: "📟", name: "ASCII Reference Table", slug: "/ascii-table", desc: "Interactive ASCII & Unicode character lookup" },
  { emoji: "🌈", name: "CSS Gradient Generator", slug: "/gradient-generator", desc: "Create gradients visually with preset gallery" },
  { emoji: "🖼️", name: "Box Shadow Generator", slug: "/box-shadow", desc: "Design CSS box shadows with multi-layer support" },
  { emoji: "📐", name: "Flexbox Playground", slug: "/flexbox-playground", desc: "Interactive CSS Flexbox layout builder" },
  { emoji: "📐", name: "CSS Grid Generator", slug: "/grid-generator", desc: "Visual CSS Grid designer with template areas" },
  { emoji: "🔗", name: "URL Slug Generator", slug: "/slug-generator", desc: "Convert text to URL slugs with Unicode support" },
  { emoji: "📋", name: "Schema Markup Generator", slug: "/schema-generator", desc: "Generate JSON-LD structured data" },
  { emoji: "🔑", name: "JWT Debugger", slug: "/jwt-debugger", desc: "Decode JWT tokens & validate expiration" },
  { emoji: "🛡️", name: "CSP Header Generator", slug: "/csp-generator", desc: "Build Content Security Policy headers visually" },
  { emoji: "📡", name: "HTTP Status Code Reference", slug: "/http-status", desc: "Interactive status code lookup with examples" },
  { emoji: "🎯", name: "JSON Path Tester", slug: "/json-path", desc: "Test JSONPath expressions with live results" },
  { emoji: "🔄", name: "TOML Converter", slug: "/toml-converter", desc: "Convert TOML, JSON, YAML with validation" },
  { emoji: "🗺️", name: "XML Sitemap Generator", slug: "/sitemap-generator", desc: "Create XML sitemaps with priority & frequency" },
  { emoji: "⏰", name: "Crontab Guru", slug: "/crontab-guru", desc: "Explain cron expressions in plain English" },
  { emoji: "🌐", name: "DNS Lookup Tool", slug: "/dns-lookup", desc: "Query DNS records: A, AAAA, MX, NS, TXT, CNAME" },
  { emoji: "🔍", name: "WHOIS Lookup", slug: "/whois-lookup", desc: "Check domain registration & nameserver details" },
  { emoji: "📧", name: "Email Address Validator", slug: "/email-validator", desc: "Validate email format, MX records, syntax" },
  { emoji: "📍", name: "IP Address Lookup", slug: "/ip-lookup", desc: "IP geolocation, ISP, ASN & reverse DNS lookup" },
  { emoji: "🌐", name: "User Agent Parser", slug: "/user-agent-parser", desc: "Parse browser, OS, device from user agent strings" },
  { emoji: "🔒", name: "SSL Certificate Checker", slug: "/ssl-checker", desc: "Check SSL certificate details & validity" },
  { emoji: "⬜", name: "Border Radius Generator", slug: "/border-radius", desc: "Design CSS border-radius visually" },
  { emoji: "🔠", name: "Text Transform Tool", slug: "/text-transform", desc: "Transform text case: camelCase, snake_case, etc" },
  { emoji: "⚙️", name: "Nginx Config Generator", slug: "/nginx-config", desc: "Generate Nginx server blocks & redirects" },
  { emoji: "🐳", name: "Docker Compose Generator", slug: "/docker-compose", desc: "Build docker-compose.yml files visually" },
  { emoji: "📖", name: "README Generator", slug: "/readme-generator", desc: "Generate professional README.md with preview" },
  { emoji: "🔏", name: "Privacy Policy Generator", slug: "/privacy-policy", desc: "GDPR/CCPA compliant privacy policy generator" },
  { emoji: "📜", name: "Terms of Service Generator", slug: "/terms-generator", desc: "Generate customizable Terms of Service" },
  { emoji: "🙈", name: "Gitignore Generator", slug: "/gitignore-generator", desc: "Generate .gitignore for any language/framework" },
  { emoji: "⚖️", name: "License Picker", slug: "/license-picker", desc: "Compare open source licenses & generate LICENSE file" },
  { emoji: "⚙️", name: ".htaccess Generator", slug: "/htaccess-generator", desc: "Generate Apache .htaccess rules & redirects" },
  { emoji: "🔤", name: "Font Size Converter", slug: "/font-size-converter", desc: "Convert px, rem, em, pt, vw units" },
  { emoji: "🎨", name: "Tailwind CSS Converter", slug: "/tailwind-converter", desc: "Convert vanilla CSS to Tailwind utility classes" },
  { emoji: "🌐", name: "CORS Tester", slug: "/cors-tester", desc: "Test CORS headers on any URL" },
  { emoji: "📂", name: "Recursive chmod Generator", slug: "/chmod-recursive", desc: "Generate recursive chmod commands for directories" },
  { emoji: "✨", name: "SVG Optimizer", slug: "/svg-optimizer", desc: "Optimize SVG files by removing metadata" },
  { emoji: "🖼️", name: "Image to Base64", slug: "/image-to-base64", desc: "Convert images to Base64 data URIs" },
  { emoji: "📐", name: "Aspect Ratio Calculator", slug: "/aspect-ratio-calc", desc: "Calculate image/video aspect ratios" },
  { emoji: "🔢", name: "Em Calculator", slug: "/em-calculator", desc: "Convert em, rem, px with custom base sizes" },
  { emoji: "🖼️", name: "OG Image Preview", slug: "/og-image-preview", desc: "Preview Open Graph images for social sharing" }
];

// Studies (specific files matching criteria + overrides)
const studies = [
  { emoji: "🔒", name: "HTTP Security Headers Study 2026", slug: "/security-headers-study", desc: "85 top websites analyzed for 10 critical HTTP security headers", stat: "Only 13%", statLabel: "score an A grade" },
  { emoji: "🎨", name: "CSS Framework File Size Comparison", slug: "/css-framework-sizes", desc: "30 frameworks measured — Bootstrap to Bulma file size analysis", stat: "30", statLabel: "frameworks compared" },
  { emoji: "⚖️", name: "Web Page Weight Study 2026", slug: "/page-weight-study", desc: "Full resource breakdown of 100 top websites", stat: "2.2 MB", statLabel: "average page weight" },
  { emoji: "📊", name: "API Response Times Study", slug: "/api-response-times", desc: "Response time analysis across major APIs", stat: "< 200ms", statLabel: "average response time" }
];

// Guides (files starting with "guide-")
const guides = [
  { emoji: "📚", name: "Git Commands Cheat Sheet", slug: "/guide-git-commands", desc: "Essential Git commands: init, clone, branch, merge, rebase" },
  { emoji: "📡", name: "HTTP Headers Guide", slug: "/guide-http-headers", desc: "Complete guide to HTTP headers with security examples" },
  { emoji: "🎯", name: "CSS Selectors Reference", slug: "/guide-css-selectors", desc: "Comprehensive CSS selector cheat sheet" },
  { emoji: "🗄️", name: "SQL Quick Reference", slug: "/guide-sql-basics", desc: "SQL cheat sheet: SELECT, JOINs, GROUP BY, subqueries" },
  { emoji: "⌨️", name: "Vim Cheat Sheet", slug: "/guide-vim", desc: "Vim reference: modes, navigation, editing, search" },
  { emoji: "📚", name: "HTML Elements Reference", slug: "/guide-html-elements", desc: "Complete HTML5 element reference with examples" },
  { emoji: "🐳", name: "Docker Commands Guide", slug: "/guide-docker", desc: "Docker CLI reference with Dockerfile patterns" },
  { emoji: "📝", name: "Markdown Syntax Guide", slug: "/guide-markdown", desc: "Complete Markdown reference with tables & code blocks" },
  { emoji: "📚", name: "cURL Commands Guide", slug: "/guide-curl", desc: "cURL reference: GET, POST, headers, auth, file upload" },
  { emoji: "⌨️", name: "Terminal Commands Guide", slug: "/guide-terminal", desc: "Essential terminal commands for developers" },
  { emoji: "🤖", name: "Prompting Jules Guide", slug: "/guide-prompting-jules", desc: "How to effectively prompt Google's Jules AI coding agent" }
];

// Lists (files starting with "list-")
const lists = [
  { emoji: "📋", name: "VS Code Extensions", slug: "/list-vscode-extensions", desc: "Top VS Code extensions for web development" },
  { emoji: "📋", name: "Monospace Fonts for Coding", slug: "/list-monospace-fonts", desc: "Best coding fonts with ligature support" },
  { emoji: "📋", name: "CSS Frameworks Compared", slug: "/list-css-frameworks", desc: "Tailwind, Bootstrap, Bulma comparison" },
  { emoji: "📋", name: "Free Static Hosting", slug: "/list-static-hosting", desc: "GitHub Pages, Netlify, Vercel, Cloudflare Pages" },
  { emoji: "📋", name: "Free Icon Sets", slug: "/list-icon-sets", desc: "Lucide, Heroicons, Phosphor, Tabler icon libraries" },
  { emoji: "📋", name: "Static Site Generators", slug: "/list-ssg", desc: "Astro, Hugo, Eleventy, Next.js comparison" },
  { emoji: "📋", name: "API Testing Tools", slug: "/list-api-testing", desc: "Postman, Insomnia, Hoppscotch comparison" },
  { emoji: "📋", name: "Color Tools for Designers", slug: "/list-color-tools", desc: "Palette generators, contrast checkers, gradient makers" }
];
---
<html lang="en">
<head>
  <BaseHead />
  <title>siliconbased.dev — Developer Tools & Research</title>
  <meta name="description" content="Free developer tools and original research. JSON, JWT, regex, cron, colors, timestamps, security studies, and performance analysis." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, sans-serif; 
      background: #060a12; 
      color: #c8d0de; 
      line-height: 1.6;
    }

    /* Hero */
    .hero { 
      text-align: center; 
      padding: 100px 24px 70px; 
      background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); 
      position: relative; 
    }
    .hero::before { 
      content: ''; 
      position: absolute; 
      inset: 0; 
      background: radial-gradient(circle at 40% 30%, rgba(129,140,248,0.06) 0%, transparent 60%); 
    }
    .hero-content { position: relative; z-index: 1; }
    .hero .tagline { 
      color: #818cf8; 
      font-size: 0.85rem; 
      font-weight: 700; 
      letter-spacing: 3px; 
      text-transform: uppercase; 
      margin-bottom: 16px; 
    }
    .hero h1 { 
      font-size: 3rem; 
      font-weight: 900; 
      letter-spacing: -1.5px; 
      margin-bottom: 20px; 
      background: linear-gradient(135deg, #fff 0%, #818cf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { 
      color: #5a6a80; 
      font-size: 1.05rem; 
      max-width: 520px; 
      margin: 0 auto; 
    }

    /* Sections */
    .section-container { 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 60px 24px; 
    }
    .section-header { 
      text-align: center; 
      margin-bottom: 40px; 
    }
    .section-tag { 
      display: inline-block; 
      background: rgba(129,140,248,0.1); 
      color: #818cf8; 
      font-size: 0.7rem; 
      font-weight: 800; 
      padding: 6px 16px; 
      border-radius: 20px; 
      letter-spacing: 1px; 
      margin-bottom: 12px; 
    }
    .section-title { 
      font-size: 2.2rem; 
      font-weight: 900; 
      color: #fff; 
      margin-bottom: 8px; 
      letter-spacing: -0.8px; 
    }
    .section-sub { 
      color: #5a6a80; 
      font-size: 1rem; 
    }

    /* Tools Grid */
    .tools-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 16px; 
    }
    .tool-card { 
      background: #111318; 
      border: 1px solid #1e2030; 
      border-radius: 12px; 
      padding: 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .tool-card:hover { 
      border-color: #818cf8; 
      transform: translateY(-2px); 
    }
    .tool-emoji { 
      font-size: 1.4rem; 
      margin-bottom: 8px; 
      display: block; 
    }
    .tool-name { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .tool-desc { 
      font-size: 0.8rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Studies Grid */
    .studies-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
      gap: 24px; 
    }
    .study-card { 
      background: linear-gradient(135deg, #0a1020 0%, #0d1428 100%); 
      border: 1px solid #1a2332; 
      border-radius: 16px; 
      padding: 28px 24px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.3s ease; 
      position: relative; 
      overflow: hidden; 
    }
    .study-card::before { 
      content: ''; 
      position: absolute; 
      top: 0; 
      left: 0; 
      right: 0; 
      height: 2px; 
      background: linear-gradient(90deg, #818cf8, #6366f1); 
      opacity: 0; 
      transition: opacity 0.3s; 
    }
    .study-card:hover { 
      border-color: #818cf8; 
      transform: translateY(-3px); 
      box-shadow: 0 12px 40px rgba(129,140,248,0.15); 
    }
    .study-card:hover::before { opacity: 1; }
    
    .study-emoji { 
      font-size: 1.6rem; 
      margin-bottom: 12px; 
      display: block; 
    }
    .study-stat { 
      margin-bottom: 16px; 
    }
    .stat-number { 
      display: block; 
      font-size: 2rem; 
      font-weight: 900; 
      color: #818cf8; 
      line-height: 1; 
      letter-spacing: -1px; 
    }
    .stat-label { 
      display: block; 
      font-size: 0.75rem; 
      color: #5a6a80; 
      margin-top: 4px; 
    }
    .study-name { 
      font-size: 1rem; 
      font-weight: 800; 
      color: #e0e8f0; 
      margin-bottom: 8px; 
      line-height: 1.3; 
    }
    .study-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Guides & Lists Grid */
    .guides-grid, .lists-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
      gap: 20px; 
    }
    .guide-card, .list-card { 
      background: #0f1419; 
      border: 1px solid #1a2028; 
      border-radius: 14px; 
      padding: 24px 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .guide-card:hover, .list-card:hover { 
      border-color: #818cf8; 
      transform: translateY(-2px); 
    }
    .guide-emoji, .list-emoji { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
      display: block; 
    }
    .guide-name, .list-name { 
      font-size: 1rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .guide-desc, .list-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Footer */
    .footer { 
      text-align: center; 
      padding: 50px 24px; 
      font-size: 0.85rem; 
      color: #3a4a5a; 
      border-top: 1px solid #151f2e; 
      background: #040810; 
    }
    .footer a { 
      color: #818cf8; 
      text-decoration: none; 
    }
    .footer a:hover { 
      text-decoration: underline; 
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .section-container { padding: 40px 20px; }
      .tools-grid { grid-template-columns: 1fr; }
      .studies-grid, .guides-grid, .lists-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Developer Tools & Research</div>
      <h1>siliconbased.dev</h1>
      <p>Free developer tools and original research. JSON, JWT, regex, cron, colors, timestamps, security studies, and performance analysis.</p>
    </div>
  </div>

  <!-- Tools Section -->
  {tools.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🛠️ TOOLS</span>
        <h2 class="section-title">Developer Tools</h2>
        <p class="section-sub">Free, client-side, no signup. Built for devs who ship fast.</p>
      </div>
      <div class="tools-grid">
        {tools.map(tool => (
          <a class="tool-card" href={tool.slug}>
            <span class="tool-emoji">{tool.emoji}</span>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Studies Section -->
  {studies.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🔬 RESEARCH</span>
        <h2 class="section-title">Original Studies</h2>
        <p class="section-sub">Real data nobody else has packaged. Crawled, measured, analyzed.</p>
      </div>
      <div class="studies-grid">
        {studies.map(study => (
          <a class="study-card" href={study.slug}>
            <span class="study-emoji">{study.emoji}</span>
            <div class="study-stat">
              <span class="stat-number">{study.stat}</span>
              <span class="stat-label">{study.statLabel}</span>
            </div>
            <h3 class="study-name">{study.name}</h3>
            <p class="study-desc">{study.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Guides Section -->
  {guides.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📚 GUIDES</span>
        <h2 class="section-title">Developer Guides</h2>
        <p class="section-sub">Cheat sheets and references for common dev tasks.</p>
      </div>
      <div class="guides-grid">
        {guides.map(guide => (
          <a class="guide-card" href={guide.slug}>
            <span class="guide-emoji">{guide.emoji}</span>
            <h3 class="guide-name">{guide.name}</h3>
            <p class="guide-desc">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Lists Section -->
  {lists.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📋 LISTS</span>
        <h2 class="section-title">Curated Lists</h2>
        <p class="section-sub">Best tools, libraries, and resources for developers.</p>
      </div>
      <div class="lists-grid">
        {lists.map(list => (
          <a class="list-card" href={list.slug}>
            <span class="list-emoji">{list.emoji}</span>
            <h3 class="list-name">{list.name}</h3>
            <p class="list-desc">{list.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    © 2026 <a href="/">siliconbased.dev</a> · A <a href="https://gab.ae">GAB Ventures</a> property
  </div>
</body>
</html>