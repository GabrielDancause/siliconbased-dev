<html lang="en">
<head>
  <BaseHead
    title="Silicon Based — Developer Tools & Digital Utilities"
    description="Free developer tools, digital marketing utilities, creator analytics, and e-commerce calculators. Built for devs who ship fast."
    ogTitle="Silicon Based — Dev Tools That Don't Suck"
    ogDescription="Free developer tools and digital utilities. JSON, JWT, regex, cron, colors, timestamps and more."
  />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0a0b10; color: #e0e0e0; }
    .hero {
      text-align: center;
      padding: 100px 24px 80px;
      background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%);
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 40% 30%, rgba(99,102,241,0.06) 0%, transparent 60%);
    }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 {
      font-size: 3.2rem;
      font-weight: 900;
      letter-spacing: -1.5px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #fff 0%, #818cf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { color: #666; font-size: 1.05rem; max-width: 480px; margin: 0 auto; }

    .grid {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px 100px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 16px;
    }
    .tool-card {
      background: #111318;
      border: 2px solid #1e2030;
      border-radius: 16px;
      padding: 32px 28px;
      text-decoration: none;
      color: inherit;
      display: block;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
      position: relative;
    }
    .tool-card:hover { border-color: #818cf8; transform: translateY(-3px); box-shadow: 0 8px 30px rgba(99,102,241,0.1); }
    .tool-card .badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: #818cf8;
      color: #0a0b10;
      font-size: 0.65rem;
      font-weight: 800;
      padding: 3px 10px;
      border-radius: 20px;
      letter-spacing: 0.5px;
    }
    .tool-card .badge.live {
      background: #34d399;
    }
    .tool-card .emoji { font-size: 2.2rem; margin-bottom: 14px; display: block; }
    .tool-card h2 { font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 8px; }
    .tool-card p { font-size: 0.88rem; color: #888; line-height: 1.6; }
    .tool-card .arrow { color: #818cf8; font-size: 0.85rem; margin-top: 14px; display: inline-block; font-weight: 600; }

    /* Section layout */
    .section-container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
    .section-header { text-align: center; margin-bottom: 32px; padding-top: 20px; }
    .section-tag { display: inline-block; background: #1a1b2e; color: #818cf8; font-size: 0.7rem; font-weight: 800; padding: 4px 14px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 12px; }
    .section-title { font-size: 1.8rem; font-weight: 900; color: #fff; margin-bottom: 6px; letter-spacing: -0.5px; }
    .section-desc { color: #555; font-size: 0.92rem; }

    /* Studies */
    .studies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px; margin-bottom: 60px; }
    .study-card { background: linear-gradient(135deg, #111318 0%, #0e1020 100%); border: 2px solid #1e2030; border-radius: 20px; padding: 32px 28px; text-decoration: none; color: inherit; display: block; transition: border-color 0.3s, transform 0.2s; position: relative; overflow: hidden; }
    .study-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #818cf8, #6366f1); opacity: 0; transition: opacity 0.3s; }
    .study-card:hover { border-color: #818cf8; transform: translateY(-3px); }
    .study-card:hover::before { opacity: 1; }
    .study-tag { display: inline-block; background: rgba(129,140,248,0.12); color: #818cf8; font-size: 0.6rem; font-weight: 800; padding: 3px 10px; border-radius: 12px; letter-spacing: 0.8px; margin-bottom: 16px; }
    .study-stat { margin-bottom: 16px; }
    .stat-number { display: block; font-size: 2.4rem; font-weight: 900; color: #818cf8; line-height: 1; letter-spacing: -1px; }
    .stat-label { display: block; font-size: 0.82rem; color: #666; margin-top: 4px; }
    .study-title { font-size: 1.15rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .study-subtitle { font-size: 0.8rem; color: #818cf8; margin-bottom: 10px; font-weight: 600; }
    .study-desc { font-size: 0.85rem; color: #777; line-height: 1.6; margin-bottom: 16px; }
    .study-cta { color: #818cf8; font-size: 0.85rem; font-weight: 700; }

    /* Tools grid */
    .grid { margin-bottom: 60px; }

    .footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #333; border-top: 1px solid #151520; }
    .footer a { color: #818cf8; text-decoration: none; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .grid { grid-template-columns: 1fr; padding: 0 16px 60px; }
      .studies-grid { grid-template-columns: 1fr; }
      .stat-number { font-size: 2rem; }
    }
  </style>
</head>
<body>
<div class="hero">
  <div class="hero-content">
    <h1>silicon based</h1>
    <p>Free developer tools that don't suck. Built for devs who ship fast.</p>
  </div>
</div>
<div class="section-container">
  <div class="section-header">
    <span class="section-tag">🔬 ORIGINAL RESEARCH</span>
    <h2 class="section-title">Featured Studies</h2>
    <p class="section-desc">Real data nobody else has packaged. Crawled, measured, and analyzed by us.</p>
  </div>
  <div class="studies-grid">
    {studies.map(s => (
      <a class="study-card" href={s.slug}>
        <span class="study-tag">{s.tag}</span>
        <div class="study-stat">
          <span class="stat-number">{s.stat}</span>
          <span class="stat-label">{s.statLabel}</span>
        </div>
        <h3 class="study-title">{s.title}</h3>
        <p class="study-subtitle">{s.subtitle}</p>
        <p class="study-desc">{s.desc}</p>
        <span class="study-cta">Read the study →</span>
      </a>
    ))}
  </div>
</div>

<div class="section-container">
  <div class="section-header">
    <span class="section-tag">🛠️ TOOLS</span>
    <h2 class="section-title">Developer Tools</h2>
    <p class="section-desc">Free, client-side, no signup. Built for devs who ship fast.</p>
  </div>
  <div class="grid">
    {tools.map(tool => (
      <a class="tool-card" href={tool.slug}>
        {tool.badge && <span class={`badge ${tool.badge === 'LIVE' ? 'live' : ''}`}>{tool.badge}</span>}
        <span class="emoji">{tool.emoji}</span>
        <h2>{tool.name}</h2>
        <p>{tool.desc}</p>
        <span class="arrow">Try it →</span>
      </a>
    ))}
  </div>
</div>
<div class="footer">
  © 2025 <a href="https://siliconbased.dev">siliconbased.dev</a> · A <a href="https://gab.ae">GAB Ventures</a> property
</div>
</body>
</html>
