---
import BaseHead from './BaseHead.astro';
const { page } = Astro.props;
const accent = page.accentColor || '#0F1729';
---
<html lang="en">
<head>
    <BaseHead title={page.title} description={page.description} ogTitle={page.ogTitle} ogDescription={page.ogDescription} />
    <style define:vars={{ accent }}>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fafafa; color: #1a1a1a; line-height: 1.7; }
        .hero { color: #fff; padding: 48px 24px 36px; text-align: center; }
        .hero h1 { font-size: 2rem; font-weight: 700; margin-bottom: 8px; }
        .hero .tagline { font-size: 1rem; opacity: 0.85; max-width: 540px; margin: 0 auto; }
        .container { max-width: 720px; margin: 0 auto; padding: 32px 20px 60px; }
        .tool-card { background: #fff; border-radius: 16px; padding: 32px 28px; border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 32px; }
        .tool-card h2 { font-size: 1.2rem; color: var(--accent); margin-bottom: 16px; }
        .tool-card label { display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 6px; margin-top: 14px; }
        .tool-card input, .tool-card select { width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; }
        .tool-card input:focus, .tool-card select:focus { outline: none; border-color: var(--accent); }
        .tool-card .result { background: #f8f9fa; border-radius: 10px; padding: 20px; margin-top: 20px; text-align: center; }
        .tool-card .result .big { font-size: 2rem; font-weight: 700; color: var(--accent); }
        .tool-card .result .label { font-size: 0.8rem; color: #888; text-transform: uppercase; }
        .section { margin-bottom: 32px; }
        .section h2 { font-size: 1.4rem; font-weight: 700; color: var(--accent); margin-bottom: 14px; }
        .section p { font-size: 0.94rem; color: #555; line-height: 1.8; margin-bottom: 12px; }
        .footer { text-align: center; padding: 40px 24px; font-size: 0.82rem; color: #aaa; border-top: 1px solid #eee; }
        .footer a { color: var(--accent); text-decoration: none; }
        @media (max-width: 600px) {
            .hero { padding: 36px 18px 28px; }
            .hero h1 { font-size: 1.6rem; }
            .tool-card { padding: 24px 18px; }
        }
    </style>
</head>
<body>
<div class="hero" style={`background: ${page.heroGradient};`}>
    <h1 set:html={page.h1} />
    {page.tagline && <p class="tagline">{page.tagline}</p>}
</div>
<div class="container">
    {page.toolHtml && <div class="tool-card" set:html={page.toolHtml} />}
    {page.sections?.map((section: any) => (
        <div class="section">
            <h2>{section.title}</h2>
            {section.paragraphs?.map((p: string) => <p set:html={p} />)}
        </div>
    ))}
</div>
{page.footer && <div class="footer"><p set:html={page.footer} /></div>}
</body>
</html>
